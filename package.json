{
  "name": "ask-em",
  "description": "Sync prompts across AI chat providers",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "lint": "eslint .",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "cf:login": "wrangler login",
    "cf:dev": "wrangler --cwd cloudflare dev",
    "cf:deploy": "wrangler --cwd cloudflare deploy",
    "cf:d1:create": "wrangler --cwd cloudflare d1 create ask-em-model-requests",
    "cf:d1:migrate:local": "wrangler --cwd cloudflare d1 migrations apply DB --local",
    "cf:d1:migrate:remote": "wrangler --cwd cloudflare d1 migrations apply DB --remote",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.81.1",
    "wxt": "^0.20.20"
  }
}
